# Frontend / scripts
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Edge function runtime (Supabase Functions)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres

# Optional: override default edge function URL for seeding
EDGE_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/server

# Optional for Prisma CLI usage (schema mirror)
DATABASE_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres
